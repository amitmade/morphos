{
  "name": "@morphos/engine",
  "version": "1.0.0",
  "description": "Framework-agnostic design system generation logic.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "build": "tsup src/index.ts --format cjs,esm --minify --dts",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/culori": "^4.0.1",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "culori": "^4.0.1",
    "zod": "^3.23.8"
  }
}
